<h2><%= @artist.name %></h2>

<div class="summary-grid">
  <div class="card">
    <div class="label">Song count</div>
    <div class="value" data-test="song-count"><%= @summary[:song_count] %></div>
  </div>
  <div class="card">
    <div class="label">Top genres</div>
    <div class="value" data-test="top-genres">
      <% if @summary[:top_genres].any? %>
        <% @summary[:top_genres].each do |g| %>
          <span class="tag"><%= g %></span>
        <% end %>
      <% else %>
        <em>none</em>
      <% end %>
    </div>
  </div>
  <div class="card">
    <div class="label">Featured song</div>
    <div class="value" data-test="featured-song">
      <% if @artist.featured_song %>
        <span class="tag featured-badge"><%= @artist.featured_song.title %></span>
      <% else %>
        <em>none</em>
      <% end %>
    </div>
  </div>
</div>

<div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
  <%= link_to "Add song", new_artist_song_path(@artist), class: "btn" %>
  <%= link_to "Edit artist", edit_artist_path(@artist), class: "btn btn-secondary" %>
  <%= button_to "Delete artist", artist_path(@artist), method: :delete, class: "btn btn-danger",
                data: { confirm: "Are you sure?" } %>
</div>

<h3>Songs</h3>

<% if @songs.empty? %>
  <p class="card">No songs yet. <%= link_to "Add one", new_artist_song_path(@artist) %>.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Genres</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @songs.each do |song| %>
        <tr>
          <td><%= song.title %></td>
          <td>
            <% song.genres.order(:name).each do |g| %>
              <span class="tag"><%= g.name %></span>
            <% end %>
          </td>
          <td>
            <% if @artist.featured_song_id == song.id %>
              <span class="tag featured-badge">Featured</span>
            <% end %>
          </td>
          <td style="display: flex; gap: 0.4rem;">
            <% if @artist.featured_song_id != song.id %>
              <%= button_to "Mark featured",
                            feature_artist_song_path(@artist, song),
                            method: :patch, class: "btn btn-secondary" %>
            <% end %>
            <%= button_to "Remove",
                          artist_song_path(@artist, song),
                          method: :delete, class: "btn btn-danger",
                          data: { confirm: "Remove this song?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<p style="margin-top: 1rem"><%= link_to "Back to artists", artists_path %></p>
